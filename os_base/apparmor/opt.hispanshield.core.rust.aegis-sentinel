#include <tunables/global>
#include <abstractions/base>
#include <abstractions/nameservice>
#include <abstractions/openssl>

# AppArmor profile for the Aegis Sentinel orchestrator.
# Hardened in Fase 2: removed sys_ptrace and sys_admin (privilege escalation
# vectors that contradicted Zero-Trust). Sentinel does NOT need them.
/opt/hispanshield/core/rust/target/release/aegis-sentinel {
    capability net_bind_service,

    network inet  stream,
    network inet6 stream,
    network unix  stream,

    # Read-only access to system configs (no writes).
    /etc/hispanshield/** r,
    /etc/secureboot/**   r,
    /etc/tpm/**          r,

    # The credentials directory injected by systemd LoadCredential lives under
    # /run/credentials/<unit>/<name>; allow read-only.
    /run/credentials/aegis-agent-core.service/** r,

    # Read access to Rust core binaries; no write to itself.
    /opt/hispanshield/core/rust/** r,
    /opt/hispanshield/core/rust/target/release/aegis-sentinel mr,

    # Write access only to the explicit log/data directories.
    /var/log/hispanshield/**          rw,
    /var/lib/hispanshield/**          rw,
    /opt/hispanshield/core/data/**    rw,

    # IPC sockets.
    /run/aegis-sentinel.sock rw,
    /run/aegis-*.sock        rw,

    # Hard denies.
    deny /home/**                rwklx,
    deny /root/**                rwklx,
    deny @{PROC}/@{pid}/mem      rwklx,
    deny @{PROC}/@{pid}/cmdline  w,
    deny @{PROC}/sys/kernel/**   w,
    deny /etc/shadow             rwklx,
    deny /etc/passwd             w,
    deny /sys/kernel/**          w,
    deny mount,
    deny umount,
    deny ptrace,
}
