## HispanShield OS — I2P Tunnel Configuration (Backup C2 channel)
## Generated by spectre_c2.sh

## Server tunnel: accepts connections from I2P network, forwards to C2 listener
[c2-server]
type = server
host = 127.0.0.1
port = __C2_PORT__
inport = __I2P_INPORT__
keys = c2-server.dat
gzip = true
accesslist =
# Encryption: ElGamal + AES-256
crypto.tagsToSend = 40
crypto.tagsSendThreshold = 10
# Streaming protocol
i2p.streaming.initialAckDelay = 0
